<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" /> <!-- Allows internet to be used in the app -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" /> <!-- Allows exact location to be used in the app -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" /> <!-- Allows rough location to be used in the app -->
    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.YeshLatet"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter> <!-- Selects the activity to be the first one to open up -->
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Register Acitvities -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".SignupActivity"
            android:exported="false" />

        <activity
            android:name=".BusinessHomeActivity"
            android:exported="false" />

        <activity
            android:name=".CharityHomeActivity"
            android:exported="false" />

        <activity
            android:name=".VolunteerHomeActivity"
            android:exported="false" />
        <activity
            android:name=".SubmitFoodActivity"
            android:exported="false" />
        <activity
            android:name=".FoodListActivity"
            android:exported="false" />
        <activity
            android:name=".ChatActivity"
            android:exported="false" />
        <activity
            android:name=".ChatListActivity"
            android:exported="false" />
        <activity
            android:name=".RequestVolunteerActivity"
            android:exported="false" />

        <activity
            android:name=".VolunteerRequestsActivity"
            android:exported="false" />
    </application>

</manifest>