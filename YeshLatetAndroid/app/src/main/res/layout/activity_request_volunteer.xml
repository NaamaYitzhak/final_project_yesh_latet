<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF4F4"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:layoutDirection="rtl">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="בקשת מתנדב"
            android:textColor="#7A1E2C"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/logoImage"
            app:layout_constraintBottom_toTopOf="@id/requestInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/requestInput"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:hint="כתוב מה צריך, לדוגמה: צריך מתנדב שיעזור באיסוף אוכל ממסעדה במרכז העיר"
            android:textDirection="rtl"
            android:gravity="top|right"
            android:background="@drawable/input_background"
            android:padding="18dp"
            android:inputType="textMultiLine"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintBottom_toTopOf="@id/infoText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/infoText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="הבקשה תופיע אצל כל המתנדבים. מתנדב שמעוניין לעזור יוכל לפתוח איתך צ׳אט."
            android:textAlignment="center"
            android:textColor="#8A5A5A"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/requestInput"
            app:layout_constraintBottom_toTopOf="@id/sendButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendButton"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:text="פרסם בקשה"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="30dp"
            app:backgroundTint="#E96F88"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/infoText"
            app:layout_constraintBottom_toTopOf="@id/backButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:text="חזרה"
            android:textSize="16sp"
            android:textColor="#E96F88"
            android:layout_marginTop="12dp"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#E96F88"
            app:strokeWidth="2dp"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/sendButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>