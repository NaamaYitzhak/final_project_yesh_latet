<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF4F4"
    android:padding="24dp"
    android:layoutDirection="rtl">

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="135dp"
        android:layout_height="135dp"
        android:src="@drawable/logo"
        android:scaleType="fitCenter"
        android:contentDescription="Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="שלום מתנדב"
        android:textColor="#7A1E2C"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/logoImage"
        app:layout_constraintBottom_toTopOf="@id/subtitleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="כאן ניתן לראות תרומות ומשימות באזור ולעזור בהובלה, העמסה ופריקה"
        android:textAlignment="center"
        android:textColor="#8A5A5A"
        android:textSize="16sp"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintBottom_toTopOf="@id/mapCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/mapCard"
        android:layout_width="0dp"
        android:layout_height="170dp"
        android:text="🗺️\nמשימות באזור"
        android:textSize="24sp"
        android:textColor="#5E2A2A"
        android:gravity="center"
        android:background="@drawable/card_background"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/subtitleText"
        app:layout_constraintBottom_toTopOf="@id/foodListButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/foodListButton"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="צפייה בתרומות"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="28dp"
        app:backgroundTint="#E96F88"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toBottomOf="@id/mapCard"
        app:layout_constraintBottom_toTopOf="@id/tasksButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/tasksButton"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="משימות התנדבות"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#E96F88"
        android:layout_marginTop="12dp"
        app:backgroundTint="#FFFFFF"
        app:strokeColor="#E96F88"
        app:strokeWidth="2dp"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toBottomOf="@id/foodListButton"
        app:layout_constraintBottom_toTopOf="@id/chatButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/chatButton"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="צ׳אטים"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#E96F88"
        android:layout_marginTop="12dp"
        app:backgroundTint="#FFFFFF"
        app:strokeColor="#E96F88"
        app:strokeWidth="2dp"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toBottomOf="@id/tasksButton"
        app:layout_constraintBottom_toTopOf="@id/logoutButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/logoutButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="התנתקות"
        android:textSize="16sp"
        android:textColor="#7A1E2C"
        android:layout_marginTop="12dp"
        app:backgroundTint="#FFFFFF"
        app:strokeColor="#7A1E2C"
        app:strokeWidth="2dp"
        app:cornerRadius="26dp"
        app:layout_constraintTop_toBottomOf="@id/chatButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>