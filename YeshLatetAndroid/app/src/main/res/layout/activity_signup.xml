<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF4F4"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:layoutDirection="rtl">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="135dp"
            android:layout_height="135dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הרשמה"
            android:textColor="#7A1E2C"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/logoImage"
            app:layout_constraintBottom_toTopOf="@id/usernameInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/usernameInput"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:hint="שם משתמש"
            android:textDirection="rtl"
            android:background="@drawable/input_background"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:singleLine="true"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintBottom_toTopOf="@id/emailInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:hint="אימייל"
            android:inputType="textEmailAddress"
            android:textDirection="ltr"
            android:background="@drawable/input_background"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:singleLine="true"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/usernameInput"
            app:layout_constraintBottom_toTopOf="@id/passwordInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:hint="סיסמה"
            android:inputType="textPassword"
            android:textDirection="rtl"
            android:background="@drawable/input_background"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:singleLine="true"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/emailInput"
            app:layout_constraintBottom_toTopOf="@id/typeTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/typeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="סוג משתמש"
            android:textColor="#7A1E2C"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/passwordInput"
            app:layout_constraintBottom_toTopOf="@id/typeRadioGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/typeRadioGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/input_background"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/typeTitle"
            app:layout_constraintBottom_toTopOf="@id/signupButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/businessRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="עסק"
                android:textSize="16sp"
                android:textColor="#5E2A2A"
                android:buttonTint="#E96F88" />

            <RadioButton
                android:id="@+id/charityRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="עמותה"
                android:textSize="16sp"
                android:textColor="#5E2A2A"
                android:buttonTint="#E96F88" />

            <RadioButton
                android:id="@+id/volunteerRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="מתנדב"
                android:textSize="16sp"
                android:textColor="#5E2A2A"
                android:buttonTint="#E96F88" />

        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/signupButton"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:text="צור חשבון"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="26dp"
            app:backgroundTint="#E96F88"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/typeRadioGroup"
            app:layout_constraintBottom_toTopOf="@id/backButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:text="חזרה"
            android:textSize="16sp"
            android:textColor="#E96F88"
            android:layout_marginTop="12dp"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#E96F88"
            app:strokeWidth="2dp"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/signupButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>